//@version=6
indicator("Revesal Pro", overlay=true)

//#include "zigzag.pine"

left = input.int(5, "Left", minval=1)
right = input.int(5, "Right", minval=1)
zigzagWidth = input.int(2, "ZigZag Line Width")
threshold = input.float(1.5, "Threshold", minval=0.0)
thresholdIsPercent = input.bool(true, "Threshold is Percent")
upColor = input.color(color.new(color.lime, 0), "Up ZigZag Color")
downColor = input.color(color.new(color.red, 0), "Down ZigZag Color")

zigzagValue = zigzag_core(high, low, left, right, threshold, thresholdIsPercent)

// @function 現在の ZigZag バーインデックスを取得する
// @param right 右側確定バー数
// @return 確定済み ZigZag バーの bar_index
int current_zigzag_bar(int right) =>
    bar_index - right

// @function ZigZag 描画が可能かどうか判定する
bool is_zigzag_point_available(float zigzagValue, int right) =>
    not na(zigzagValue) and current_zigzag_bar(right) >= 0

// @function ZigZag の色を取得する
color get_zigzag_color(bool isUp, color upColor, color downColor) =>
    isUp ? upColor : downColor

// @function ZigZag のラベルスタイルを取得する
label.style get_zigzag_label_style(bool isUp) =>
    isUp ? label.style_label_up : label.style_label_down

// @function ZigZag のラベル文字列を取得する
string get_zigzag_label_text(bool isUp) =>
    isUp ? "H" : "L"

zigzag_draw(float zigzagValue, int zigzagWidth, color upColor, color downColor, int right) =>
    var int prevZigzagBar = na
    var float prevZigzagPrice = na
    int currentZigzagBar = current_zigzag_bar(right)

    if is_zigzag_point_available(zigzagValue, right)
        if na(prevZigzagPrice)
            prevZigzagBar := currentZigzagBar
            prevZigzagPrice := zigzagValue
        else if zigzagValue != prevZigzagPrice
            bool isUp = zigzagValue > prevZigzagPrice
            color dirColor = get_zigzag_color(isUp, upColor, downColor)
            label.style labelStyle = get_zigzag_label_style(isUp)
            string labelText = get_zigzag_label_text(isUp)

            line.new(prevZigzagBar, prevZigzagPrice, currentZigzagBar, zigzagValue,
                xloc = xloc.bar_index,
                color = dirColor,
                width = zigzagWidth,
                extend = extend.none)
            label.new(currentZigzagBar, zigzagValue,
                text = labelText,
                xloc = xloc.bar_index,
                color = color.new(dirColor, 0),
                textcolor = color.white,
                style = labelStyle,
                size = size.tiny)
            prevZigzagBar := currentZigzagBar
            prevZigzagPrice := zigzagValue

zigzag_draw(zigzagValue, zigzagWidth, upColor, downColor, right)
