// @function 一般的なPivotベースZigZagを描画する
// @param なし
// @return なし
zz_run() =>
	int PIVOT_TYPE_NONE = 0
	int PIVOT_TYPE_UP = 1
	int PIVOT_TYPE_DOWN = -1
	string SIGNAL_TEXT_PROMO = "PROMO"
	string SIGNAL_TEXT_REV_UP = "REV↑"
	string SIGNAL_TEXT_REV_DOWN = "REV↓"
	int TABLE_COLUMNS = 2
	int TABLE_ROWS = 4
	int TABLE_LAST_COLUMN_INDEX = 1
	int TABLE_LAST_ROW_INDEX = 3
	int SIGNAL_TEXT_OPAQUE = 0
	string FIB_OPTION_23_6 = "23.6%"
	string FIB_OPTION_38_2 = "38.2%"

	// フェーズ0基準値。後続フェーズはこの初期入力と表示挙動を壊さないことを前提に拡張する。
	int leftBars = input.int(5, "Pivot左バー数", minval=1, tooltip="ピボット確定に必要な左側バー数")
	int rightBars = input.int(5, "Pivot右バー数", minval=1, tooltip="ピボット確定に必要な右側バー数")
	float baseDeviationPercent = input.float(1.0, "基準最小変化率(%)", minval=0.1, step=0.1, tooltip="有効なZoneレンジが未形成の間に使う反転しきい値")
	float discountDeviationPercent = input.float(1.0, "Discount側最小変化率(%)", minval=0.1, step=0.1, tooltip="価格がレンジ下半分(Discount)にある時の反転しきい値")
	float premiumDeviationPercent = input.float(1.0, "Premium側最小変化率(%)", minval=0.1, step=0.1, tooltip="価格がレンジ上半分(Premium)にある時の反転しきい値")
	bool useWickProvisionalPivot = input.bool(true, "髭で仮ピボット即時候補", tooltip="ONで反対方向の候補をバー高値/安値で即時認定し、確定は既存しきい値で判定")
	bool requireFibPromotion = input.bool(false, "Fib昇格必須で確定", tooltip="ONで反転候補が選択Fib比率に到達した場合のみ確定を許可")
	string fibPromotionLevel = input.string(FIB_OPTION_23_6, "昇格Fib比率", options=[FIB_OPTION_23_6, FIB_OPTION_38_2], tooltip="昇格判定に使う戻し比率")
	bool useErAdaptiveFib = input.bool(true, "ER連動で昇格Fib比率を切替", tooltip="ONでERに応じて強い相場23.6%、弱い相場38.2%を自動適用")
	int erPeriod = input.int(20, "ER期間", minval=2, tooltip="Efficiency Ratioを算出する期間")
	float erThreshold = input.float(0.45, "ER強弱閾値", minval=0.0, maxval=1.0, step=0.01, tooltip="ERがこの値以上なら強い相場として扱う")
	bool showHud = input.bool(true, "HUDを表示", tooltip="現在Zone、ER状態、適用Fib比率、最新確定方向を表示")
	bool showSignals = input.bool(true, "シグナルを表示", tooltip="Fib昇格成立と確定反転の2種類シグナルを表示")
	int maxSignalLabels = input.int(120, "シグナル保持本数", minval=20, maxval=300, tooltip="古いシグナルラベルは自動削除")
	int maxLines = input.int(300, "表示ライン本数", minval=50, maxval=500, tooltip="古いZigZagラインは自動削除")
	bool showRealtimeLeg = input.bool(true, "未確定レッグを表示", tooltip="最後の確定ピボットから現在値への点線を表示")
	color upColor = input.color(color.new(color.lime, 0), "上昇レッグ色")
	color downColor = input.color(color.new(color.red, 0), "下降レッグ色")
	int lineWidth = input.int(2, "ライン幅", minval=1, maxval=4)
	float manualFibRatio = f_get_fib_ratio_from_label(fibPromotionLevel)
	float efficiencyRatioValue = f_calc_efficiency_ratio(close, erPeriod)
	bool hasStrongTrend = efficiencyRatioValue >= erThreshold
	float adaptiveFibRatio = hasStrongTrend ? ZZ_FIB_RATIO_23_6 : ZZ_FIB_RATIO_38_2
	float appliedFibRatio = useErAdaptiveFib ? adaptiveFibRatio : manualFibRatio

	// フェーズ0基準: ta.pivot* による確定候補だけを使う。
	float pivotHigh = ta.pivothigh(high, leftBars, rightBars)
	float pivotLow = ta.pivotlow(low, leftBars, rightBars)
	bool hasPivotHigh = not na(pivotHigh)
	bool hasPivotLow = not na(pivotLow)
	int pivotTime = time[rightBars]

	// フェーズ1: 確定ピボット状態を管理する。
	var int confirmedPivotType = PIVOT_TYPE_NONE
	var float confirmedPivotPrice = na
	var int confirmedPivotTime = na
	var int previousConfirmedPivotType = PIVOT_TYPE_NONE
	var float previousConfirmedPivotPrice = na
	var int previousConfirmedPivotTime = na

	// フェーズ1: 仮ピボット候補状態を管理する。
	var int candidatePivotType = PIVOT_TYPE_NONE
	var float candidatePivotPrice = na
	var int candidatePivotTime = na

	// フェーズ1: 描画状態を管理する。
	var array<line> confirmedLegLines = array.new<line>()
	var line realtimeLegLine = na
	var table hudTable = table.new(position.top_right, TABLE_COLUMNS, TABLE_ROWS, border_width=1)
	var array<label> signalLabels = array.new<label>()

	// フェーズ6: Fib昇格シグナルの重複通知を抑制する。
	var int promotionCandidateType = PIVOT_TYPE_NONE
	var bool promotionLatched = false

	// フェーズ2: Zone判定に使う直近確定レンジ高安を管理する。
	var float confirmedRangeHigh = na
	var float confirmedRangeLow = na

	bool isZoneRangeAvailable = not na(confirmedRangeHigh) and not na(confirmedRangeLow) and confirmedRangeHigh > confirmedRangeLow
	float zoneMidPrice = isZoneRangeAvailable ? confirmedRangeLow + (confirmedRangeHigh - confirmedRangeLow) * 0.5 : na
	bool isPriceInPremiumZone = isZoneRangeAvailable and close >= zoneMidPrice
	float activeDeviationPercent = isZoneRangeAvailable ? (isPriceInPremiumZone ? premiumDeviationPercent : discountDeviationPercent) : baseDeviationPercent
	int barStartConfirmedType = confirmedPivotType
	bool fibPromotionSignal = false
	float fibPromotionSignalPrice = na
	int fibPromotionSignalTime = na
	bool reversalConfirmSignal = false
	float reversalConfirmSignalPrice = na
	int reversalConfirmSignalTime = na

	bool hasUpperCandidate = hasPivotHigh or (useWickProvisionalPivot and barStartConfirmedType == PIVOT_TYPE_DOWN and not na(confirmedPivotPrice))
	float upperCandidatePrice = hasPivotHigh ? pivotHigh : high
	int upperCandidateTime = hasPivotHigh ? pivotTime : time

	bool hasLowerCandidate = hasPivotLow or (useWickProvisionalPivot and barStartConfirmedType == PIVOT_TYPE_UP and not na(confirmedPivotPrice))
	float lowerCandidatePrice = hasPivotLow ? pivotLow : low
	int lowerCandidateTime = hasPivotLow ? pivotTime : time

	if hasPivotHigh and hasPivotLow
		if confirmedPivotType == PIVOT_TYPE_UP
			hasPivotHigh := false
		else if confirmedPivotType == PIVOT_TYPE_DOWN
			hasPivotLow := false
		else
			hasPivotLow := false

	if hasUpperCandidate
		candidatePivotType := PIVOT_TYPE_UP
		candidatePivotPrice := upperCandidatePrice
		candidatePivotTime := upperCandidateTime
		if na(confirmedPivotPrice)
			confirmedPivotType := candidatePivotType
			confirmedPivotPrice := candidatePivotPrice
			confirmedPivotTime := candidatePivotTime
			confirmedRangeHigh := candidatePivotPrice
		else if confirmedPivotType == candidatePivotType
			bool moreExtreme = candidatePivotPrice > confirmedPivotPrice
			if moreExtreme
				// 同方向のより強い高値が出た場合は、直近レッグ終点のみ更新して過剰確定を防ぐ。
				confirmedPivotPrice := candidatePivotPrice
				confirmedPivotTime := candidatePivotTime
				confirmedRangeHigh := candidatePivotPrice
				if array.size(confirmedLegLines) > 0
					line prevLine = array.get(confirmedLegLines, array.size(confirmedLegLines) - 1)
					line.set_xy2(prevLine, candidatePivotTime, candidatePivotPrice)
		else
			float changePct = f_calc_change_pct(confirmedPivotPrice, candidatePivotPrice)
			float baseLegLength = na(previousConfirmedPivotPrice) ? na : math.abs(confirmedPivotPrice - previousConfirmedPivotPrice)
			float reversalMoveLength = math.abs(candidatePivotPrice - confirmedPivotPrice)
			bool isFibPromoted = f_check_fib_promotion(baseLegLength, reversalMoveLength, appliedFibRatio)
			if promotionCandidateType != candidatePivotType
				promotionCandidateType := candidatePivotType
				promotionLatched := false
			if isFibPromoted and not promotionLatched
				fibPromotionSignal := true
				fibPromotionSignalPrice := candidatePivotPrice
				fibPromotionSignalTime := candidatePivotTime
				promotionLatched := true
			bool passesFibPromotion = f_can_confirm_by_fib_promotion(baseLegLength, reversalMoveLength, appliedFibRatio, requireFibPromotion)
			if changePct >= activeDeviationPercent and passesFibPromotion
				// 反転は最小変化率を満たした時のみ確定し、基準線として保持する。
				color legColor = candidatePivotType == 1 ? upColor : downColor
				line newLine = line.new(confirmedPivotTime, confirmedPivotPrice, candidatePivotTime, candidatePivotPrice, xloc=xloc.bar_time, color=legColor, width=lineWidth)
				array.push(confirmedLegLines, newLine)
				if array.size(confirmedLegLines) > maxLines
					line oldLine = array.shift(confirmedLegLines)
					line.delete(oldLine)
				previousConfirmedPivotType := confirmedPivotType
				previousConfirmedPivotPrice := confirmedPivotPrice
				previousConfirmedPivotTime := confirmedPivotTime
				confirmedPivotType := candidatePivotType
				confirmedPivotPrice := candidatePivotPrice
				confirmedPivotTime := candidatePivotTime
				confirmedRangeHigh := candidatePivotPrice
				reversalConfirmSignal := true
				reversalConfirmSignalPrice := candidatePivotPrice
				reversalConfirmSignalTime := candidatePivotTime
				promotionCandidateType := PIVOT_TYPE_NONE
				promotionLatched := false

	if hasLowerCandidate
		candidatePivotType := PIVOT_TYPE_DOWN
		candidatePivotPrice := lowerCandidatePrice
		candidatePivotTime := lowerCandidateTime
		if na(confirmedPivotPrice)
			confirmedPivotType := candidatePivotType
			confirmedPivotPrice := candidatePivotPrice
			confirmedPivotTime := candidatePivotTime
			confirmedRangeLow := candidatePivotPrice
		else if confirmedPivotType == candidatePivotType
			bool moreExtreme = candidatePivotPrice < confirmedPivotPrice
			if moreExtreme
				// 同方向のより強い安値が出た場合は、直近レッグ終点のみ更新して過剰確定を防ぐ。
				confirmedPivotPrice := candidatePivotPrice
				confirmedPivotTime := candidatePivotTime
				confirmedRangeLow := candidatePivotPrice
				if array.size(confirmedLegLines) > 0
					line prevLine = array.get(confirmedLegLines, array.size(confirmedLegLines) - 1)
					line.set_xy2(prevLine, candidatePivotTime, candidatePivotPrice)
		else
			float changePct = f_calc_change_pct(confirmedPivotPrice, candidatePivotPrice)
			float baseLegLength = na(previousConfirmedPivotPrice) ? na : math.abs(confirmedPivotPrice - previousConfirmedPivotPrice)
			float reversalMoveLength = math.abs(candidatePivotPrice - confirmedPivotPrice)
			bool isFibPromoted = f_check_fib_promotion(baseLegLength, reversalMoveLength, appliedFibRatio)
			if promotionCandidateType != candidatePivotType
				promotionCandidateType := candidatePivotType
				promotionLatched := false
			if isFibPromoted and not promotionLatched
				fibPromotionSignal := true
				fibPromotionSignalPrice := candidatePivotPrice
				fibPromotionSignalTime := candidatePivotTime
				promotionLatched := true
			bool passesFibPromotion = f_can_confirm_by_fib_promotion(baseLegLength, reversalMoveLength, appliedFibRatio, requireFibPromotion)
			if changePct >= activeDeviationPercent and passesFibPromotion
				// 反転は最小変化率を満たした時のみ確定し、基準線として保持する。
				color legColor = candidatePivotType == 1 ? upColor : downColor
				line newLine = line.new(confirmedPivotTime, confirmedPivotPrice, candidatePivotTime, candidatePivotPrice, xloc=xloc.bar_time, color=legColor, width=lineWidth)
				array.push(confirmedLegLines, newLine)
				if array.size(confirmedLegLines) > maxLines
					line oldLine = array.shift(confirmedLegLines)
					line.delete(oldLine)
				previousConfirmedPivotType := confirmedPivotType
				previousConfirmedPivotPrice := confirmedPivotPrice
				previousConfirmedPivotTime := confirmedPivotTime
				confirmedPivotType := candidatePivotType
				confirmedPivotPrice := candidatePivotPrice
				confirmedPivotTime := candidatePivotTime
				confirmedRangeLow := candidatePivotPrice
				reversalConfirmSignal := true
				reversalConfirmSignalPrice := candidatePivotPrice
				reversalConfirmSignalTime := candidatePivotTime
				promotionCandidateType := PIVOT_TYPE_NONE
				promotionLatched := false

	if showSignals
		if fibPromotionSignal and not na(fibPromotionSignalPrice)
			label promotionLabel = label.new(fibPromotionSignalTime, fibPromotionSignalPrice, SIGNAL_TEXT_PROMO, xloc=xloc.bar_time, style=label.style_label_left, textcolor=color.black, color=color.new(color.yellow, SIGNAL_TEXT_OPAQUE), size=size.tiny)
			f_append_signal_label_with_cap(signalLabels, promotionLabel, maxSignalLabels)

		if reversalConfirmSignal and not na(reversalConfirmSignalPrice)
			string reversalText = confirmedPivotType == PIVOT_TYPE_UP ? SIGNAL_TEXT_REV_UP : SIGNAL_TEXT_REV_DOWN
			reversalStyle = confirmedPivotType == PIVOT_TYPE_UP ? label.style_label_up : label.style_label_down
			color reversalColor = confirmedPivotType == PIVOT_TYPE_UP ? upColor : downColor
			label reversalLabel = label.new(reversalConfirmSignalTime, reversalConfirmSignalPrice, reversalText, xloc=xloc.bar_time, style=reversalStyle, textcolor=color.white, color=color.new(reversalColor, 0), size=size.tiny)
			f_append_signal_label_with_cap(signalLabels, reversalLabel, maxSignalLabels)

	if showHud
		f_render_hud_minimal(hudTable, isZoneRangeAvailable, isPriceInPremiumZone, useErAdaptiveFib, hasStrongTrend, efficiencyRatioValue, appliedFibRatio, confirmedPivotType)
	else
		table.clear(hudTable, 0, 0, TABLE_LAST_COLUMN_INDEX, TABLE_LAST_ROW_INDEX)

	if not na(realtimeLegLine)
		line.delete(realtimeLegLine)
		realtimeLegLine := na

	if showRealtimeLeg and not na(confirmedPivotPrice)
		// フェーズ0基準: 未確定レッグは必ず1本だけ表示する。
		color liveColor = confirmedPivotType == PIVOT_TYPE_UP ? downColor : upColor
		realtimeLegLine := line.new(confirmedPivotTime, confirmedPivotPrice, time, close, xloc=xloc.bar_time, color=color.new(liveColor, 0), style=line.style_dotted, width=lineWidth)
