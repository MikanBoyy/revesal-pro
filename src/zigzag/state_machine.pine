// @function 日本時間のコアタイム内かを判定する
// @param なし
// @return コアタイム内ならtrue
f_is_core_time_jst() =>
    int jstHour = hour(time, "Asia/Tokyo")
    int jstMinute = minute(time, "Asia/Tokyo")
    int totalMinutes = jstHour * 60 + jstMinute
    bool isTokyoCore = totalMinutes >= 570 and totalMinutes < 660
    bool isLondonCore = totalMinutes >= 990 and totalMinutes < 1080
    bool isNewYorkCore = totalMinutes >= 1290 or totalMinutes < 60
    isTokyoCore or isLondonCore or isNewYorkCore

// @function ブレイク確定条件を評価し、連続ブレイク本数を更新する
// @param hasStrongTrend ER判定による強トレンドフラグ
// @param breakTriggered 当バーでの閾値ブレイク有無
// @param breakConfirmationCount 現在の連続ブレイク本数
// @return [ブレイク確定フラグ, 更新後の連続ブレイク本数]
f_eval_break_confirmation(hasStrongTrend, breakTriggered, breakConfirmationCount) =>
    bool shouldConfirm = false
    int nextBreakCount = breakConfirmationCount
    if hasStrongTrend
        shouldConfirm := breakTriggered
        nextBreakCount := breakTriggered ? breakConfirmationCount : 0
    else
        nextBreakCount := breakTriggered ? breakConfirmationCount + 1 : 0
        shouldConfirm := nextBreakCount >= 2
    [shouldConfirm, nextBreakCount]

// @function 指定した起点バー・方向のOBが既に存在するかを判定する
// @param activeOBs OrderBlock配列
// @param targetCreatedBar 起点バー
// @param targetDirection 方向（1=強気, -1=弱気）
// @return 既存OBがある場合はtrue
f_has_order_block_for_anchor(activeOBs, targetCreatedBar, targetDirection) =>
    bool hasDuplicate = false
    int obIndex = array.size(activeOBs) - 1
    while obIndex >= 0
        OrderBlock currentOb = array.get(activeOBs, obIndex)
        bool sameAnchor = currentOb.createdBar == targetCreatedBar and currentOb.direction == targetDirection
        if sameAnchor
            hasDuplicate := true
        obIndex := obIndex - 1
    hasDuplicate

// @function ピボット直前で最後に出現した逆色ローソク足の履歴オフセットを返す
// @param pivotBarIndex 対象ピボットのバーインデックス
// @param pivotLegStartBarIndex ピボット探索レッグの開始バーインデックス
// @param searchBearish trueなら陰線、falseなら陽線を探索
// @return 見つかった履歴オフセット（未検出はna）
f_find_last_opposite_candle_offset(pivotBarIndex, pivotLegStartBarIndex, searchBearish) =>
    int oppositeOffset = na
    int pivotOffset = bar_index - pivotBarIndex
    int oldestOffset = bar_index - pivotLegStartBarIndex
    bool canSearch = not na(pivotBarIndex) and not na(pivotLegStartBarIndex) and pivotOffset >= 0 and oldestOffset >= pivotOffset + 1

    if canSearch
        int scanOffset = pivotOffset + 1
        while scanOffset <= oldestOffset and na(oppositeOffset)
            bool bearishBar = close[scanOffset] < open[scanOffset]
            bool bullishBar = close[scanOffset] > open[scanOffset]
            bool isMatched = searchBearish ? bearishBar : bullishBar
            if isMatched
                oppositeOffset := scanOffset
            scanOffset := scanOffset + 1

    oppositeOffset

// @function 高安値追従型ZigZagを描画する
// @param なし
// @return なし
zz_run() =>
    int PIVOT_TYPE_NONE = 0
    int PIVOT_TYPE_UP = 1
    int PIVOT_TYPE_DOWN = -1
    int SR_ROLE_RESISTANCE = 1
    int SR_ROLE_SUPPORT = -1
    int SR_STATE_ACTIVE = 1
    int SR_STATE_FLIPPED = 2
    int SR_STATE_BROKEN = 3
    int OB_DIRECTION_BULLISH = 1
    int OB_DIRECTION_BEARISH = -1
    int OB_STATE_ACTIVE = 1
    int OB_STATE_MITIGATED = 2
    int OB_STATE_BROKEN = 3
    int REGIME_UNKNOWN = 0
    int REGIME_BULLISH = 1
    int REGIME_BEARISH = -1
    int TABLE_COLUMNS = 2
    int TABLE_ROWS = 4
    int TABLE_LAST_COLUMN_INDEX = 1
    int TABLE_LAST_ROW_INDEX = 3
    int SIGNAL_LABEL_BG_ALPHA = 86
    float SIGNAL_LABEL_OFFSET_ATR_MULTIPLIER = 0.35
    int SIGNAL_LABEL_ATR_PERIOD = 14
    string SR_CONFIRM_MODE_FIRST_EXTREME = "足1極値更新"
    string SR_CONFIRM_MODE_LINE_PRICE = "ライン価格維持"
    string OB_EXTEND_MODE_BROKEN_UNTIL = "Brokenまで延長"
    string OB_EXTEND_MODE_STOP_AT_FIRST_MITIGATION = "初回Mitigatedで延長停止"
    string OB_EXTEND_MODE_STOP_AT_TOUCH_LIMIT = "N回接触で延長停止"
    string OB_EXPIRY_ACTION_DELETE = "削除"
    string OB_EXPIRY_ACTION_DOTTED = "点線化して残す"
    color HIGH_SIDE_LABEL_COLOR = #20a35a
    color LOW_SIDE_LABEL_COLOR = #d45555
    color REVERSAL_LINE_COLOR_DEFAULT = #9932CC
    color REVERSAL_LABEL_PREMIUM_COLOR = #7A1CAC
    color REVERSAL_LABEL_NORMAL_COLOR = #8E63CE

    int atrPeriod = input.int(14, "ATR期間", minval=1, tooltip="動的反転閾値の基準となるATR期間")
    float atrMultiplier = input.float(1.8, "ATR乗数k", minval=0.1, step=0.1, tooltip="反転閾値の基礎係数（反転閾値 = (k×ATR)×(0.6+ER×0.8)）")
    int erPeriod = input.int(20, "ER期間", minval=2, tooltip="Efficiency Ratioを算出する期間")
    float erThreshold = input.float(0.45, "ER強弱閾値", minval=0.0, maxval=1.0, step=0.01, tooltip="ERがこの値以上なら1本抜け即時確定")
    color resistanceLineColor = input.color(color.new(#b97f01, 0), "Res_Color", tooltip="レジスタンスライン（有効）の色")
    color supportLineColor = input.color(color.new(#0d91dd, 0), "Sup_Color", tooltip="サポートライン（有効）の色")
    color brokenLineColor = input.color(color.new(color.gray, 0), "Broken_Line_Color", tooltip="完全に破壊されたラインの色")
    int maxHorizontalLinesCount = input.int(50, "Max_Lines_Count", minval=10, maxval=400, tooltip="チャート上に保持する最大水平ライン数")
    int expiryBarsAfterBreak = input.int(100, "Expiry_Bars_After_Break", minval=1, maxval=2000, tooltip="Broken後に何本でラインを削除するか")
    bool showHud = input.bool(true, "HUDを表示", tooltip="ER、確定モード、反転閾値、最新確定方向を表示")
    bool showSignals = input.bool(true, "シグナルを表示", tooltip="確定反転シグナルを表示")
    int maxSignalLabels = input.int(120, "シグナル保持本数", minval=20, maxval=300, tooltip="古いシグナルラベルは自動削除")
    int maxLines = input.int(300, "表示ライン本数", minval=50, maxval=500, tooltip="古いZigZagラインは自動削除")
    bool showRealtimeLeg = input.bool(true, "未確定レッグを表示", tooltip="最後の確定ピボットから現在の暫定極値への点線を表示")
    bool useBodyForPivotDetection = input.bool(false, "ZigZag判定を実体ベースにする", tooltip="ONでopen/close、OFFでhigh/lowを使って極値判定します")
    string srSecondBreakConfirmMode = input.string(SR_CONFIRM_MODE_LINE_PRICE, "レジサポ2本目確定条件", options=[SR_CONFIRM_MODE_LINE_PRICE, SR_CONFIRM_MODE_FIRST_EXTREME], tooltip="ライン価格維持: 足2終値がライン外側を維持で確定 / 足1極値更新: 足2終値が足1高安を更新で確定")
    bool showCoreTimeFvg = input.bool(false, "コアタイムFVGを表示", tooltip="日本時間コアタイム内に発生したFVGのみを描画します")
    int maxCoreTimeFvgBoxes = input.int(80, "コアタイムFVG保持数", minval=10, maxval=300, tooltip="古いFVGボックスは自動削除")
    color bullishCoreFvgColor = input.color(color.new(#1f9d55, 80), "上昇FVG色", tooltip="Low > High[2] の不均衡を描画する色")
    color bearishCoreFvgColor = input.color(color.new(#cc3d3d, 80), "下降FVG色", tooltip="High < Low[2] の不均衡を描画する色")
    bool showOB = input.bool(true, "OBを表示", tooltip="オーダーブロック機能全体の表示/非表示")
    string obSourceMode = input.string("ヒゲを含む", "OB境界モード", options=["ヒゲを含む", "実体のみ"], tooltip="OBの境界をヒゲベースにするか実体ベースにするか")
    int maxObBoxesCount = input.int(40, "OB保持数", minval=10, maxval=100, tooltip="チャート上に保持するOBボックスの最大数")
    color bullishObColor = input.color(#1f9d55, "通常強気OB色", tooltip="通常の強気OBの描画色")
    color bearishObColor = input.color(#cc3d3d, "通常弱気OB色", tooltip="通常の弱気OBの描画色")
    color premiumObColor = input.color(#7A1CAC, "Premium OB色", tooltip="機関性裏付けのあるPremium OBの描画色")
    int obAlphaActive = input.int(70, "OB透明度（有効時）", minval=0, maxval=100, tooltip="アクティブなOBの背景透明度")
    int obAlphaMitigated = input.int(75, "OB透明度（吸収済）", minval=0, maxval=100, tooltip="吸収済OBの背景透明度")
    string obExtendMode = input.string(OB_EXTEND_MODE_BROKEN_UNTIL, "OB延長モード", options=[OB_EXTEND_MODE_BROKEN_UNTIL, OB_EXTEND_MODE_STOP_AT_FIRST_MITIGATION, OB_EXTEND_MODE_STOP_AT_TOUCH_LIMIT], tooltip="Balanced推奨: Brokenまで延長。必要に応じて接触基準で停止に切替できます")
    int obMitigationTouchLimit = input.int(1, "OB延長停止の接触回数", minval=1, maxval=10, tooltip="延長モードがN回接触で延長停止の場合に使用します")
    int obMaxAgeBars = input.int(600, "OB寿命（バー数）", minval=10, maxval=2000, tooltip="作成から指定バー経過後は寿命切れとして処理します")
    string obExpiryAction = input.string(OB_EXPIRY_ACTION_DELETE, "OB寿命到達時の処理", options=[OB_EXPIRY_ACTION_DELETE, OB_EXPIRY_ACTION_DOTTED], tooltip="寿命経過後に削除するか、点線化して残すかを選択します")
    color reversalLineColor = input.color(color.new(REVERSAL_LINE_COLOR_DEFAULT, 0), "転換ライン色", tooltip="転換確定ラインを強調表示する色")
    int reversalLineWidth = input.int(2, "転換ライン太さ", minval=2, maxval=5, tooltip="転換確定時のライン太さ")
    int maxReversalLinesCount = input.int(40, "転換ライン保持本数", minval=30, maxval=50, tooltip="レジーム転換専用ラインの最大保持本数（古い順に削除）")
    color upColor = input.color(color.new(color.lime, 0), "上昇レッグ色")
    color downColor = input.color(color.new(color.red, 0), "下降レッグ色")
    int lineWidth = input.int(4, "ライン幅", minval=1, maxval=4)

    float atrValue = ta.atr(atrPeriod)
    float efficiencyRatioValue = f_calc_efficiency_ratio(close, erPeriod)
    bool hasStrongTrend = efficiencyRatioValue >= erThreshold
    float thresholdPriceRaw = f_calc_dynamic_threshold_price(atrValue, efficiencyRatioValue, atrMultiplier)
    float thresholdPrice = math.max(thresholdPriceRaw, syminfo.mintick)
    float signalLabelOffsetPrice = ta.atr(SIGNAL_LABEL_ATR_PERIOD) * SIGNAL_LABEL_OFFSET_ATR_MULTIPLIER
    float pivotSourceHigh = useBodyForPivotDetection ? math.max(open, close) : high
    float pivotSourceLow = useBodyForPivotDetection ? math.min(open, close) : low
    bool isCoreTime = f_is_core_time_jst()
    bool hasBullishFvg = bar_index >= 2 and low > high[2]
    bool hasBearishFvg = bar_index >= 2 and high < low[2]
    bool hasCoreTimeBullishFvg = isCoreTime and hasBullishFvg
    bool hasCoreTimeBearishFvg = isCoreTime and hasBearishFvg
    bool barHasCoreTimeFvg = hasCoreTimeBullishFvg or hasCoreTimeBearishFvg
    int barsSinceCoreTimeFvg = ta.barssince(barHasCoreTimeFvg)
    bool hasCoreTimeFvgWithin3Bars = not na(barsSinceCoreTimeFvg) and barsSinceCoreTimeFvg <= 3

    var int confirmedPivotType = PIVOT_TYPE_NONE
    var float confirmedPivotPrice = na
    var int confirmedPivotTime = na
    var int confirmedPivotBarIndex = na
    var float lastConfirmedHighPivotPrice = na
    var float lastConfirmedLowPivotPrice = na
    var int lastConfirmedHighPivotBarIndex = na
    var int lastConfirmedLowPivotBarIndex = na
    var int lastConfirmedHighLegStartBarIndex = na
    var int lastConfirmedLowLegStartBarIndex = na

    // activeLegDirection=UPは暫定高値を追跡中、DOWNは暫定安値を追跡中を示す。
    var int activeLegDirection = PIVOT_TYPE_NONE
    var float legExtremePrice = na
    var int legExtremeTime = na
    var int legExtremeBarIndex = na
    var int breakConfirmationCount = 0

    var array<line> confirmedLegLines = array.new<line>()
    var line realtimeLegLine = na
    var table hudTable = table.new(position.bottom_left, TABLE_COLUMNS, TABLE_ROWS, border_width=1)
    var array<label> signalLabels = array.new<label>()
    var array<SRLine> horizontalLines = array.new<SRLine>()
    var array<line> reversalLines = array.new<line>()
    var array<box> coreTimeFvgBoxes = array.new<box>()
    var array<OrderBlock> activeOBs = array.new<OrderBlock>()
    var bool institutionalSignalActive = false
    var float lastTargetHL = na
    var float lastTargetLH = na
    var int currentRegime = REGIME_UNKNOWN

    bool reversalConfirmSignal = false
    float reversalConfirmSignalPrice = na
    int reversalConfirmSignalTime = na
    string reversalSignalLabelText = ""
    string reversalPivotClass = ""
    color reversalSignalLabelColor = na
    bool regimeShiftConfirmedSignal = false
    bool regimeShiftIsPremium = false
    bool regimeShiftIsBullish = false
    float regimeShiftSignalPrice = na
    int regimeShiftSignalTime = na
    bool createBullishObFromRegimeShift = false
    bool createBearishObFromRegimeShift = false

    if barHasCoreTimeFvg
        institutionalSignalActive := true

    if showCoreTimeFvg
        if hasCoreTimeBullishFvg
            box bullishFvgBox = box.new(bar_index - 2, low, bar_index, high[2], bgcolor=bullishCoreFvgColor, border_color=color.new(bullishCoreFvgColor, 0), xloc=xloc.bar_index)
            f_append_box_with_cap(coreTimeFvgBoxes, bullishFvgBox, maxCoreTimeFvgBoxes)
        if hasCoreTimeBearishFvg
            box bearishFvgBox = box.new(bar_index - 2, low[2], bar_index, high, bgcolor=bearishCoreFvgColor, border_color=color.new(bearishCoreFvgColor, 0), xloc=xloc.bar_index)
            f_append_box_with_cap(coreTimeFvgBoxes, bearishFvgBox, maxCoreTimeFvgBoxes)

    if na(confirmedPivotPrice)
        confirmedPivotPrice := close
        confirmedPivotTime := time
        confirmedPivotBarIndex := bar_index
        if bar_index > 0
            activeLegDirection := close >= close[1] ? PIVOT_TYPE_UP : PIVOT_TYPE_DOWN
        else
            activeLegDirection := PIVOT_TYPE_UP
        legExtremePrice := activeLegDirection == PIVOT_TYPE_UP ? pivotSourceHigh : pivotSourceLow
        legExtremeTime := time
        legExtremeBarIndex := bar_index
        breakConfirmationCount := 0

    if activeLegDirection == PIVOT_TYPE_UP
        if na(legExtremePrice) or pivotSourceHigh >= legExtremePrice
            legExtremePrice := pivotSourceHigh
            legExtremeTime := time
            legExtremeBarIndex := bar_index
            breakConfirmationCount := 0

        float downBreakLine = legExtremePrice - thresholdPrice
        bool breakTriggered = close < downBreakLine
        [shouldConfirm, nextBreakCount] = f_eval_break_confirmation(hasStrongTrend, breakTriggered, breakConfirmationCount)
        breakConfirmationCount := nextBreakCount

        if shouldConfirm and not na(legExtremePrice) and not na(legExtremeTime)
            color legColor = upColor
            line newLine = line.new(confirmedPivotTime, confirmedPivotPrice, legExtremeTime, legExtremePrice, xloc=xloc.bar_time, color=legColor, width=lineWidth)
            array.push(confirmedLegLines, newLine)
            if array.size(confirmedLegLines) > maxLines
                line oldLine = array.shift(confirmedLegLines)
                line.delete(oldLine)

            int legStartPivotBarIndex = confirmedPivotBarIndex

            if showOB and not na(legStartPivotBarIndex)
                int bearishAnchorOffset = f_find_last_opposite_candle_offset(legExtremeBarIndex, legStartPivotBarIndex, false)
                if not na(bearishAnchorOffset)
                    int bearishAnchorBar = bar_index - bearishAnchorOffset
                    bool bearishObIsPremium = hasCoreTimeFvgWithin3Bars and hasStrongTrend
                    bool hasDuplicateBearishOb = f_has_order_block_for_anchor(activeOBs, bearishAnchorBar, OB_DIRECTION_BEARISH)

                    if not hasDuplicateBearishOb
                        float bearishTopPrice = high[bearishAnchorOffset]
                        float bearishBottomPrice = obSourceMode == "実体のみ" ? math.min(open[bearishAnchorOffset], close[bearishAnchorOffset]) : low[bearishAnchorOffset]
                        color bearishBaseColor = bearishObIsPremium ? premiumObColor : bearishObColor
                        box bearishObBox = box.new(bearishAnchorBar, bearishTopPrice, bar_index, bearishBottomPrice, xloc=xloc.bar_index, bgcolor=color.new(bearishBaseColor, obAlphaActive), border_width=0)
                        OrderBlock bearishOrderBlock = OrderBlock.new(bearishObBox, bearishTopPrice, bearishBottomPrice, OB_DIRECTION_BEARISH, bearishObIsPremium, bearishAnchorBar, OB_STATE_ACTIVE, efficiencyRatioValue, 0, false, false)
                        array.push(activeOBs, bearishOrderBlock)
                        f_trim_order_blocks_with_cap(activeOBs, maxObBoxesCount)

            confirmedPivotType := PIVOT_TYPE_UP
            confirmedPivotPrice := legExtremePrice
            confirmedPivotTime := legExtremeTime
            confirmedPivotBarIndex := legExtremeBarIndex
            bool isHigherHigh = na(lastConfirmedHighPivotPrice) or legExtremePrice >= lastConfirmedHighPivotPrice
            reversalSignalLabelText := isHigherHigh ? "HH" : "LH"
            reversalPivotClass := reversalSignalLabelText
            reversalSignalLabelColor := str.substring(reversalSignalLabelText, 0, 1) == "H" ? HIGH_SIDE_LABEL_COLOR : LOW_SIDE_LABEL_COLOR
            if reversalSignalLabelText == "LH"
                lastTargetLH := legExtremePrice
            lastConfirmedHighPivotPrice := legExtremePrice
            lastConfirmedHighPivotBarIndex := legExtremeBarIndex
            lastConfirmedHighLegStartBarIndex := legStartPivotBarIndex
            reversalConfirmSignal := true
            reversalConfirmSignalPrice := legExtremePrice
            reversalConfirmSignalTime := legExtremeTime

            activeLegDirection := PIVOT_TYPE_DOWN
            legExtremePrice := pivotSourceLow
            legExtremeTime := time
            legExtremeBarIndex := bar_index
            breakConfirmationCount := 0
            institutionalSignalActive := false

    else if activeLegDirection == PIVOT_TYPE_DOWN
        if na(legExtremePrice) or pivotSourceLow <= legExtremePrice
            legExtremePrice := pivotSourceLow
            legExtremeTime := time
            legExtremeBarIndex := bar_index
            breakConfirmationCount := 0

        float upBreakLine = legExtremePrice + thresholdPrice
        bool breakTriggered = close > upBreakLine
        [shouldConfirm, nextBreakCount] = f_eval_break_confirmation(hasStrongTrend, breakTriggered, breakConfirmationCount)
        breakConfirmationCount := nextBreakCount

        if shouldConfirm and not na(legExtremePrice) and not na(legExtremeTime)
            color legColor = downColor
            line newLine = line.new(confirmedPivotTime, confirmedPivotPrice, legExtremeTime, legExtremePrice, xloc=xloc.bar_time, color=legColor, width=lineWidth)
            array.push(confirmedLegLines, newLine)
            if array.size(confirmedLegLines) > maxLines
                line oldLine = array.shift(confirmedLegLines)
                line.delete(oldLine)

            int legStartPivotBarIndex = confirmedPivotBarIndex

            if showOB and not na(legStartPivotBarIndex)
                int bullishAnchorOffset = f_find_last_opposite_candle_offset(legExtremeBarIndex, legStartPivotBarIndex, true)
                if not na(bullishAnchorOffset)
                    int bullishAnchorBar = bar_index - bullishAnchorOffset
                    bool bullishObIsPremium = hasCoreTimeFvgWithin3Bars and hasStrongTrend
                    bool hasDuplicateBullishOb = f_has_order_block_for_anchor(activeOBs, bullishAnchorBar, OB_DIRECTION_BULLISH)

                    if not hasDuplicateBullishOb
                        float bullishTopPrice = obSourceMode == "実体のみ" ? math.max(open[bullishAnchorOffset], close[bullishAnchorOffset]) : high[bullishAnchorOffset]
                        float bullishBottomPrice = low[bullishAnchorOffset]
                        color bullishBaseColor = bullishObIsPremium ? premiumObColor : bullishObColor
                        box bullishObBox = box.new(bullishAnchorBar, bullishTopPrice, bar_index, bullishBottomPrice, xloc=xloc.bar_index, bgcolor=color.new(bullishBaseColor, obAlphaActive), border_width=0)
                        OrderBlock bullishOrderBlock = OrderBlock.new(bullishObBox, bullishTopPrice, bullishBottomPrice, OB_DIRECTION_BULLISH, bullishObIsPremium, bullishAnchorBar, OB_STATE_ACTIVE, efficiencyRatioValue, 0, false, false)
                        array.push(activeOBs, bullishOrderBlock)
                        f_trim_order_blocks_with_cap(activeOBs, maxObBoxesCount)

            confirmedPivotType := PIVOT_TYPE_DOWN
            confirmedPivotPrice := legExtremePrice
            confirmedPivotTime := legExtremeTime
            confirmedPivotBarIndex := legExtremeBarIndex
            bool isLowerLow = na(lastConfirmedLowPivotPrice) or legExtremePrice <= lastConfirmedLowPivotPrice
            reversalSignalLabelText := isLowerLow ? "LL" : "HL"
            reversalPivotClass := reversalSignalLabelText
            reversalSignalLabelColor := str.substring(reversalSignalLabelText, 0, 1) == "H" ? HIGH_SIDE_LABEL_COLOR : LOW_SIDE_LABEL_COLOR
            if reversalSignalLabelText == "HL"
                lastTargetHL := legExtremePrice
            lastConfirmedLowPivotPrice := legExtremePrice
            lastConfirmedLowPivotBarIndex := legExtremeBarIndex
            lastConfirmedLowLegStartBarIndex := legStartPivotBarIndex
            reversalConfirmSignal := true
            reversalConfirmSignalPrice := legExtremePrice
            reversalConfirmSignalTime := legExtremeTime

            activeLegDirection := PIVOT_TYPE_UP
            legExtremePrice := pivotSourceHigh
            legExtremeTime := time
            legExtremeBarIndex := bar_index
            breakConfirmationCount := 0
            institutionalSignalActive := false

    bool shouldShowPivotSignalLabel = reversalSignalLabelText == "HH" or reversalSignalLabelText == "LL"
    if showSignals and reversalConfirmSignal and shouldShowPivotSignalLabel and not na(reversalConfirmSignalPrice) and str.length(reversalSignalLabelText) > 0
        float reversalLabelPrice = confirmedPivotType == PIVOT_TYPE_UP ? reversalConfirmSignalPrice + signalLabelOffsetPrice : reversalConfirmSignalPrice - signalLabelOffsetPrice
        label reversalLabel = label.new(reversalConfirmSignalTime, reversalLabelPrice, reversalSignalLabelText, xloc=xloc.bar_time, style=label.style_label_left, textcolor=color.new(reversalSignalLabelColor, 0), color=color.new(reversalSignalLabelColor, SIGNAL_LABEL_BG_ALPHA), size=size.normal)
        f_append_signal_label_with_cap(signalLabels, reversalLabel, maxSignalLabels)

    if reversalConfirmSignal and not na(confirmedPivotPrice) and not na(confirmedPivotTime)
        int initialLineRole = confirmedPivotType == PIVOT_TYPE_UP ? SR_ROLE_RESISTANCE : SR_ROLE_SUPPORT
        bool shouldShowHorizontalLine = reversalPivotClass == "HH" or reversalPivotClass == "LL"
        bool isRegimeCandidateLine = reversalPivotClass == "LH" or reversalPivotClass == "HL"
        line createdHorizontalLine = line.new(confirmedPivotTime, confirmedPivotPrice, time, confirmedPivotPrice, xloc=xloc.bar_time, extend=extend.right, color=resistanceLineColor, style=line.style_solid, width=1)
        f_apply_sr_line_style(createdHorizontalLine, SR_STATE_ACTIVE, initialLineRole, resistanceLineColor, supportLineColor, brokenLineColor, shouldShowHorizontalLine)
        SRLine newSRLine = SRLine.new(createdHorizontalLine, confirmedPivotPrice, initialLineRole, SR_STATE_ACTIVE, bar_index, na, false, na, na, false, na, shouldShowHorizontalLine, isRegimeCandidateLine)
        array.push(horizontalLines, newSRLine)

        if array.size(horizontalLines) > maxHorizontalLinesCount
            f_delete_sr_line_at(horizontalLines, 0)

    [hasRegimeShiftSignal, regimeShiftPremiumSignal, regimeShiftBullishSignal, regimeShiftPriceValue, regimeShiftTimeValue, nextRegimeState] = f_update_sr_lines(horizontalLines, reversalLines, expiryBarsAfterBreak, srSecondBreakConfirmMode, SR_CONFIRM_MODE_FIRST_EXTREME, SR_STATE_ACTIVE, SR_STATE_FLIPPED, SR_STATE_BROKEN, SR_ROLE_RESISTANCE, SR_ROLE_SUPPORT, REGIME_BULLISH, REGIME_BEARISH, currentRegime, pivotSourceHigh, pivotSourceLow, resistanceLineColor, supportLineColor, brokenLineColor, reversalLineColor, reversalLineWidth, maxReversalLinesCount, institutionalSignalActive, barHasCoreTimeFvg)
    regimeShiftConfirmedSignal := hasRegimeShiftSignal
    regimeShiftIsPremium := regimeShiftPremiumSignal
    regimeShiftIsBullish := regimeShiftBullishSignal
    regimeShiftSignalPrice := regimeShiftPriceValue
    regimeShiftSignalTime := regimeShiftTimeValue
    currentRegime := nextRegimeState

    createBullishObFromRegimeShift := regimeShiftConfirmedSignal and regimeShiftIsBullish
    createBearishObFromRegimeShift := regimeShiftConfirmedSignal and not regimeShiftIsBullish

    if showOB and createBullishObFromRegimeShift and not na(lastConfirmedLowPivotBarIndex) and not na(lastConfirmedLowLegStartBarIndex)
        int bullishAnchorOffset = f_find_last_opposite_candle_offset(lastConfirmedLowPivotBarIndex, lastConfirmedLowLegStartBarIndex, true)
        if not na(bullishAnchorOffset)
            int bullishAnchorBar = bar_index - bullishAnchorOffset
            bool bullishObIsPremium = hasCoreTimeFvgWithin3Bars and hasStrongTrend
            bool hasDuplicateBullishOb = f_has_order_block_for_anchor(activeOBs, bullishAnchorBar, OB_DIRECTION_BULLISH)

            if not hasDuplicateBullishOb
                float bullishTopPrice = obSourceMode == "実体のみ" ? math.max(open[bullishAnchorOffset], close[bullishAnchorOffset]) : high[bullishAnchorOffset]
                float bullishBottomPrice = low[bullishAnchorOffset]
                color bullishBaseColor = bullishObIsPremium ? premiumObColor : bullishObColor
                box bullishObBox = box.new(bullishAnchorBar, bullishTopPrice, bar_index, bullishBottomPrice, xloc=xloc.bar_index, bgcolor=color.new(bullishBaseColor, obAlphaActive), border_width=0)
                OrderBlock bullishOrderBlock = OrderBlock.new(bullishObBox, bullishTopPrice, bullishBottomPrice, OB_DIRECTION_BULLISH, bullishObIsPremium, bullishAnchorBar, OB_STATE_ACTIVE, efficiencyRatioValue, 0, false, false)
                array.push(activeOBs, bullishOrderBlock)
                f_trim_order_blocks_with_cap(activeOBs, maxObBoxesCount)

    if showOB and createBearishObFromRegimeShift and not na(lastConfirmedHighPivotBarIndex) and not na(lastConfirmedHighLegStartBarIndex)
        int bearishAnchorOffset = f_find_last_opposite_candle_offset(lastConfirmedHighPivotBarIndex, lastConfirmedHighLegStartBarIndex, false)
        if not na(bearishAnchorOffset)
            int bearishAnchorBar = bar_index - bearishAnchorOffset
            bool bearishObIsPremium = hasCoreTimeFvgWithin3Bars and hasStrongTrend
            bool hasDuplicateBearishOb = f_has_order_block_for_anchor(activeOBs, bearishAnchorBar, OB_DIRECTION_BEARISH)

            if not hasDuplicateBearishOb
                float bearishTopPrice = high[bearishAnchorOffset]
                float bearishBottomPrice = obSourceMode == "実体のみ" ? math.min(open[bearishAnchorOffset], close[bearishAnchorOffset]) : low[bearishAnchorOffset]
                color bearishBaseColor = bearishObIsPremium ? premiumObColor : bearishObColor
                box bearishObBox = box.new(bearishAnchorBar, bearishTopPrice, bar_index, bearishBottomPrice, xloc=xloc.bar_index, bgcolor=color.new(bearishBaseColor, obAlphaActive), border_width=0)
                OrderBlock bearishOrderBlock = OrderBlock.new(bearishObBox, bearishTopPrice, bearishBottomPrice, OB_DIRECTION_BEARISH, bearishObIsPremium, bearishAnchorBar, OB_STATE_ACTIVE, efficiencyRatioValue, 0, false, false)
                array.push(activeOBs, bearishOrderBlock)
                f_trim_order_blocks_with_cap(activeOBs, maxObBoxesCount)

    if showOB
        f_update_order_blocks(activeOBs, OB_STATE_ACTIVE, OB_STATE_MITIGATED, OB_DIRECTION_BULLISH, bullishObColor, bearishObColor, premiumObColor, obAlphaMitigated, obExtendMode, OB_EXTEND_MODE_BROKEN_UNTIL, OB_EXTEND_MODE_STOP_AT_FIRST_MITIGATION, OB_EXTEND_MODE_STOP_AT_TOUCH_LIMIT, obMitigationTouchLimit, obMaxAgeBars, obExpiryAction, OB_EXPIRY_ACTION_DELETE, OB_EXPIRY_ACTION_DOTTED, OB_STATE_BROKEN)
    else
        while array.size(activeOBs) > 0
            f_delete_order_block_at(activeOBs, 0)

    if showHud
        f_render_hud_minimal(hudTable, hasStrongTrend, efficiencyRatioValue, thresholdPrice, confirmedPivotType)
    else
        table.clear(hudTable, 0, 0, TABLE_LAST_COLUMN_INDEX, TABLE_LAST_ROW_INDEX)

    if showSignals and regimeShiftConfirmedSignal and not na(regimeShiftSignalPrice)
        string reversalArrowText = regimeShiftIsBullish ? "▲" : "▼"
        string reversalText = reversalArrowText + "TC"
        float reversalPrice = regimeShiftSignalPrice
        color reversalLabelColor = regimeShiftIsPremium ? REVERSAL_LABEL_PREMIUM_COLOR : REVERSAL_LABEL_NORMAL_COLOR
        label reversalShiftLabel = label.new(regimeShiftSignalTime, reversalPrice, reversalText, xloc=xloc.bar_time, style=label.style_label_left, textcolor=color.purple, color=color.new(reversalLabelColor, SIGNAL_LABEL_BG_ALPHA), size=size.normal)
        f_append_signal_label_with_cap(signalLabels, reversalShiftLabel, maxSignalLabels)

    if not na(realtimeLegLine)
        line.delete(realtimeLegLine)
        realtimeLegLine := na

    if showRealtimeLeg and not na(confirmedPivotPrice) and not na(legExtremePrice)
        color liveColor = activeLegDirection == PIVOT_TYPE_UP ? upColor : downColor
        realtimeLegLine := line.new(confirmedPivotTime, confirmedPivotPrice, legExtremeTime, legExtremePrice, xloc=xloc.bar_time, color=color.new(liveColor, 0), style=line.style_dotted, width=lineWidth)
