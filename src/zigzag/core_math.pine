float ZZ_FIB_RATIO_23_6 = 0.236
float ZZ_FIB_RATIO_38_2 = 0.382

// @function 2価格間の変化率(%)を算出する
// @param fromPrice 基準価格
// @param toPrice 比較先価格
// @return 変化率（%）
f_calc_change_pct(fromPrice, toPrice) =>
	float pct = fromPrice == 0.0 ? 0.0 : math.abs((toPrice - fromPrice) / fromPrice) * 100.0
	pct

// @function Fib比率ラベルから実数比率を返す
// @param fibLevelLabel Fib比率ラベル（23.6% / 38.2%）
// @return Fib比率（0.236 / 0.382）
f_get_fib_ratio_from_label(fibLevelLabel) =>
	float ratio = fibLevelLabel == "38.2%" ? ZZ_FIB_RATIO_38_2 : ZZ_FIB_RATIO_23_6
	ratio

// @function Fib昇格の成立可否を判定する
// @param baseLegLength 直近確定レッグ長
// @param reversalMoveLength 反転候補の変位量
// @param fibRatio 昇格に使うFib比率
// @return 昇格成立時 true
f_check_fib_promotion(baseLegLength, reversalMoveLength, fibRatio) =>
	bool hasBaseLeg = not na(baseLegLength) and baseLegLength > 0.0
	float requiredMoveLength = hasBaseLeg ? baseLegLength * fibRatio : 0.0
	bool isPromoted = reversalMoveLength >= requiredMoveLength
	isPromoted

// @function Fib昇格条件を満たすか判定する
// @param baseLegLength 直近確定レッグ長
// @param reversalMoveLength 反転候補の変位量
// @param fibRatio 昇格に使うFib比率
// @param requireFibPromotion 昇格必須モード
// @return 昇格条件を満たす場合 true
f_can_confirm_by_fib_promotion(baseLegLength, reversalMoveLength, fibRatio, requireFibPromotion) =>
	bool isPromoted = f_check_fib_promotion(baseLegLength, reversalMoveLength, fibRatio)
	not requireFibPromotion or isPromoted

// @function Efficiency Ratioを算出する
// @param sourceSeries 計算対象の価格系列
// @param period ER算出期間
// @return ER値（0.0-1.0）
f_calc_efficiency_ratio(sourceSeries, period) =>
	float direction = math.abs(sourceSeries - sourceSeries[period])
	float volatility = ta.sma(math.abs(sourceSeries - sourceSeries[1]), period) * period
	float er = volatility == 0.0 ? 0.0 : direction / volatility
	er
