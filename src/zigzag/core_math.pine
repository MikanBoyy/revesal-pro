// @function Efficiency Ratioを算出する
// @param sourceSeries 計算対象の価格系列
// @param period ER算出期間
// @return ER値（0.0-1.0）
f_calc_efficiency_ratio(sourceSeries, period) =>
	float direction = math.abs(sourceSeries - sourceSeries[period])
	float volatility = ta.sma(math.abs(sourceSeries - sourceSeries[1]), period) * period
	float er = volatility == 0.0 ? 0.0 : direction / volatility
	er

// @function ATRとERから動的な反転閾値（価格幅）を算出する
// @param atrValue ATR値
// @param erValue ER値（0.0-1.0）
// @param atrMultiplier ATR乗数k
// @return 反転閾値（価格幅）
f_calc_dynamic_threshold_price(atrValue, erValue, atrMultiplier) =>
	float dynamicMultiplier = 0.6 + (erValue * 0.8)
	float thresholdPrice = (atrMultiplier * atrValue) * dynamicMultiplier
	thresholdPrice

