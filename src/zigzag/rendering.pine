string ZZ_TEXT_ZONE = "Zone"
string ZZ_TEXT_ER = "ER"
string ZZ_TEXT_FIB = "Fib"
string ZZ_TEXT_DIRECTION = "方向"
string ZZ_TEXT_PREMIUM = "Premium"
string ZZ_TEXT_DISCOUNT = "Discount"
string ZZ_TEXT_RANGE_NOT_READY = "Range未形成"
string ZZ_TEXT_TREND_STRONG = "強い"
string ZZ_TEXT_TREND_WEAK = "弱い"
string ZZ_TEXT_MANUAL = "手動"
string ZZ_TEXT_DIRECTION_UP = "上方向"
string ZZ_TEXT_DIRECTION_DOWN = "下方向"
string ZZ_TEXT_DIRECTION_NONE = "未確定"
int ZZ_HUD_BG_HEADER_ALPHA = 70
int ZZ_HUD_BG_VALUE_ALPHA = 85
int ZZ_PIVOT_TYPE_UP = 1
int ZZ_PIVOT_TYPE_DOWN = -1

// @function シグナルラベルを上限制御付きで追加する
// @param signalLabels シグナルラベル配列
// @param newSignalLabel 新規ラベル
// @param maxSignalLabels 保持上限
// @return なし
f_append_signal_label_with_cap(signalLabels, newSignalLabel, maxSignalLabels) =>
	array.push(signalLabels, newSignalLabel)
	if array.size(signalLabels) > maxSignalLabels
		label oldSignalLabel = array.shift(signalLabels)
		label.delete(oldSignalLabel)

// @function HUD最小構成を描画する
// @param hudTable HUDテーブル
// @param hasZoneRange Zoneレンジ成立有無
// @param isPremiumZone Premiumゾーン判定
// @param useErAdaptiveFib ER連動有無
// @param isStrongTrend ER強弱判定
// @param erValue ER値
// @param activeFibRatio 適用Fib比率
// @param confirmedPivotType 最新確定方向
// @return なし
f_render_hud_minimal(hudTable, hasZoneRange, isPremiumZone, useErAdaptiveFib, isStrongTrend, erValue, activeFibRatio, confirmedPivotType) =>
	string hudZoneText = hasZoneRange ? (isPremiumZone ? ZZ_TEXT_PREMIUM : ZZ_TEXT_DISCOUNT) : ZZ_TEXT_RANGE_NOT_READY
	string hudErText = useErAdaptiveFib ? (isStrongTrend ? ZZ_TEXT_TREND_STRONG : ZZ_TEXT_TREND_WEAK) + " (ER=" + str.tostring(erValue, "#.###") + ")" : ZZ_TEXT_MANUAL
	string hudFibText = str.tostring(activeFibRatio * 100.0, "#.0") + "%"
	string hudDirectionText = confirmedPivotType == ZZ_PIVOT_TYPE_UP ? ZZ_TEXT_DIRECTION_UP : confirmedPivotType == ZZ_PIVOT_TYPE_DOWN ? ZZ_TEXT_DIRECTION_DOWN : ZZ_TEXT_DIRECTION_NONE

	table.cell(hudTable, 0, 0, ZZ_TEXT_ZONE, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 0, hudZoneText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 1, ZZ_TEXT_ER, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 1, hudErText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 2, ZZ_TEXT_FIB, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 2, hudFibText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 3, ZZ_TEXT_DIRECTION, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 3, hudDirectionText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
