string ZZ_TEXT_ER = "ER"
string ZZ_TEXT_FILTER = "確定モード"
string ZZ_TEXT_THRESHOLD = "閾値"
string ZZ_TEXT_DIRECTION = "方向"
string ZZ_TEXT_FILTER_FAST = "1本抜け即時"
string ZZ_TEXT_FILTER_STRICT = "2本連続確定"
string ZZ_TEXT_DIRECTION_UP = "上方向"
string ZZ_TEXT_DIRECTION_DOWN = "下方向"
string ZZ_TEXT_DIRECTION_NONE = "未確定"
int ZZ_HUD_BG_HEADER_ALPHA = 70
int ZZ_HUD_BG_VALUE_ALPHA = 85
int ZZ_PIVOT_TYPE_UP = 1
int ZZ_PIVOT_TYPE_DOWN = -1

// @function シグナルラベルを上限制御付きで追加する
// @param signalLabels シグナルラベル配列
// @param newSignalLabel 新規ラベル
// @param maxSignalLabels 保持上限
// @return なし
f_append_signal_label_with_cap(signalLabels, newSignalLabel, maxSignalLabels) =>
	array.push(signalLabels, newSignalLabel)
	if array.size(signalLabels) > maxSignalLabels
		label oldSignalLabel = array.shift(signalLabels)
		label.delete(oldSignalLabel)

// @function HUD最小構成を描画する
// @param hudTable HUDテーブル
// @param isStrongTrend ER強弱判定
// @param erValue ER値
// @param thresholdPrice 動的反転閾値（価格幅）
// @param confirmedPivotType 最新確定方向
// @return なし
f_render_hud_minimal(hudTable, isStrongTrend, erValue, thresholdPrice, confirmedPivotType) =>
	string hudErText = (isStrongTrend ? "強い" : "弱い") + " (ER=" + str.tostring(erValue, "#.###") + ")"
	string hudFilterText = isStrongTrend ? ZZ_TEXT_FILTER_FAST : ZZ_TEXT_FILTER_STRICT
	string hudThresholdText = str.tostring(thresholdPrice, "#.#####")
	string hudDirectionText = confirmedPivotType == ZZ_PIVOT_TYPE_UP ? ZZ_TEXT_DIRECTION_UP : confirmedPivotType == ZZ_PIVOT_TYPE_DOWN ? ZZ_TEXT_DIRECTION_DOWN : ZZ_TEXT_DIRECTION_NONE

	table.cell(hudTable, 0, 0, ZZ_TEXT_ER, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 0, hudErText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 1, ZZ_TEXT_FILTER, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 1, hudFilterText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 2, ZZ_TEXT_THRESHOLD, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 2, hudThresholdText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
	table.cell(hudTable, 0, 3, ZZ_TEXT_DIRECTION, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_HEADER_ALPHA))
	table.cell(hudTable, 1, 3, hudDirectionText, text_color=color.white, bgcolor=color.new(color.gray, ZZ_HUD_BG_VALUE_ALPHA))
